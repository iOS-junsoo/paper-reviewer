# ── LLM 인증 (둘 중 하나) ─────────────────────────────────────────────
# Max 구독 사용자: 터미널에서 `claude setup-token` 실행 → 발급된 토큰 입력
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# (대안) API 크레딧이 있다면 — 현재 코드는 Agent SDK 경로라 이 값은 쓰지 않음
# ANTHROPIC_API_KEY=sk-ant-...

# 사용할 모델 (기본값: claude-opus-4-8)
MODEL=claude-opus-4-8

# Firebase 서비스 계정 키 JSON 경로 (기본값: ./serviceAccountKey.json)
# 파일이 없으면 메모리 캐시로 폴백 (서버 재시작 시 결과 소실)
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json

# 서버 포트 (기본값: 3000)
PORT=3000
